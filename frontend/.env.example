# DocMind AI — Frontend Environment Variables
# Vite requires VITE_ prefix for all browser-accessible vars
# Copy to .env and fill in values. NEVER commit .env.

# Backend API base URL
# Local:      http://localhost:8000
# Production: https://your-backend.onrender.com
VITE_API_URL=http://localhost:8000

# Environment flag
VITE_ENV=development

# RAGAS Evaluation Dashboard URL (shown as link in Admin panel)
# Production: https://your-eval-dashboard.onrender.com
VITE_EVAL_DASHBOARD_URL=

# Research job status polling interval in milliseconds
VITE_RESEARCH_POLL_INTERVAL_MS=3000
